{
  "name": "",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "echo y | cross-env NODE_OPTIONS=--no-deprecation payload migrate && cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "migrate": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:create": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:create",
    "migrate:status": "cross-env NODE_OPTIONS=--no-deprecation payload migrate:status",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p 5021",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "seed": "tsx --env-file=.env tests/helpers/seed/runSeed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@videosdk.live/react-sdk": "^0.10.0",
    "@payloadcms/db-mongodb": "3.78.0",
    "@payloadcms/db-postgres": "3.78.0",
    "@payloadcms/email-nodemailer": "^3.78.0",
    "@payloadcms/next": "3.78.0",
    "@payloadcms/richtext-lexical": "3.78.0",
    "@payloadcms/storage-s3": "^3.78.0",
    "@payloadcms/ui": "3.78.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.91.2",
    "@tanstack/react-query-devtools": "^5.91.3",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "country-state-city": "^3.2.1",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "16.4.7",
    "embla-carousel-react": "^8.6.0",
    "graphql": "^16.8.1",
    "input-otp": "^1.4.2",
    "jwt-decode": "^4.0.0",
    "libphonenumber-js": "^1.12.40",
    "next": "15.4.11",
    "next-themes": "^0.4.6",
    "next13-progressbar": "^1.2.2",
    "nodemailer": "^8.0.3",
    "payload": "3.78.0",
    "postcss": "^8.5.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.1",
    "react-big-calendar": "^1.19.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.1",
    "react-icons": "^5.6.0",
    "react-phone-number-input": "^3.4.16",
    "react-resizable-panels": "^4.7.3",
    "react-select": "^5.10.2",
    "react-timezone-select": "^3.3.3",
    "recharts": "2.15.4",
    "shadcn": "^4.0.8",
    "sharp": "0.34.2",
    "slugify": "^1.6.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zeptomail": "^7.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "22.19.9",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "19.2.9",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.4.11",
    "jsdom": "28.0.0",
    "prettier": "^3.4.2",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
